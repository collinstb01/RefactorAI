env/

# Environment variables — contains secrets, never commit
.env
.env.*

# Local SQLite database file
*.db
*.sqlite3

# Distribution / packaging
dist/
build/
*.egg-info/

# IDE
.vscode/
.idea/

# macOS
.DS_Store

# pytest
.pytest_cache/
.coverage
htmlcov/
